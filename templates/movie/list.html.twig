{% extends 'base.html.twig' %}

{% block title %}Films{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1 class="mb-4">Tous les films</h1>
    
    <div class="mb-3">
        <a href="{{ path('app_movie_new') }}" class="btn btn-primary">Ajouter un film</a>
        <a href="{{ path('app_director_new') }}" class="btn btn-success">Ajouter un réalisateur</a>
    </div>
    
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Titre</th>
                <th>Année</th>
                <th>Genre</th>
                <th>Réalisateur</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for movie in movies %}
            <tr>
                <td>{{ movie.title }}</td>
                <td>{{ movie.releaseYear }}</td>
                <td>{{ movie.genre }}</td>
                <td>{{ movie.director.firstName }} {{ movie.director.lastName }}</td>
                <td>
                    <a href="{{ path('app_movie_show', {id: movie.id}) }}" class="btn btn-info btn-sm">Voir</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
